# Copy to apps/web/.env.local (Next.js) and/or repo root for drizzle-kit CLI.
# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/jobstack

# Auth.js — required: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (Vercel production URL or http://localhost:3000)
AUTH_URL=http://localhost:3000

# Google OAuth (recommended)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email magic link — Nodemailer (optional; set both to enable)
# Example: smtp://user:pass@smtp.example.com:587
EMAIL_SERVER=
EMAIL_FROM=

# PortOne — Phase 3 PR-D (택 1 또는 둘 다)
# V2 결제 웹훅: https://api.portone.io 단건 조회 검증에 사용
PORTONE_API_KEY=
# 브라우저 결제창 (@portone/browser-sdk) — 관리자 콘솔 연동 정보
NEXT_PUBLIC_PORTONE_STORE_ID=
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=
# Subscription Link (docs.portone.cloud) HMAC 검증용 — V2만 쓰면 비워도 됨
PORTONE_SUBSCRIPTION_LINK_SECRET=

# Paperclip — 구독 후 에이전트 자동 생성 (JobClaw)
# PAPERCLIP_API_URL=https://<host>
# PAPERCLIP_COMPANY_ID=
# 회사에 에이전트 생성 권한이 있는 Bearer 토큰(보드 세션 JWT 등)
# PAPERCLIP_PROVISION_BEARER_TOKEN=
# PAPERCLIP_PROVISION_ADAPTER_TYPE=cursor
# PAPERCLIP_PROVISION_REPORTS_TO_AGENT_ID=
# JSON 문자열 — adapterConfig 추가 필드 (cwd 등)
# PAPERCLIP_PROVISION_ADAPTER_CONFIG_JSON={"cwd":"/path/to/workspace"}

# JobClaw — 단일 Telegram 봇 (apps/jobclaw-telegram)
TELEGRAM_BOT_TOKEN=
# Next.js 공개: 랜딩/온보딩에서 t.me 링크 (예: https://t.me/your_bot)
NEXT_PUBLIC_JOBCLAW_TELEGRAM_URL=
JOBSTACK_WEB_URL=http://localhost:3000
# open | allowlist | deny
JOBCLAW_SUBSCRIPTION_MODE=allowlist
# allowlist 일 때 허용할 Telegram numeric user id (쉼표 구분)
JOBCLAW_ALLOWED_TELEGRAM_IDS=
# 선택: Claude Code CLI 커맨드·작업 디렉터리
# CLAUDE_CLI_COMMAND=claude
# CLAUDE_CLI_CWD=/Users/you/work/jobstack
# JOBCLAW_USER_REGISTRY_PATH=/path/to/telegram-users.json
